---
import AppShell from "../layouts/AppShell.astro";
import { getAuthSessionState, getNotificationsPageData } from "../lib/api-client";
import { renderNotificationsState } from "../components/notifications/NotificationsSurface";

const cookieHeader = Astro.request.headers.get("cookie") ?? undefined;
const auth = await getAuthSessionState({ cookieHeader });

if (!auth.authenticated) {
  return Astro.redirect("/");
}

const data = await getNotificationsPageData({ cookieHeader });
const state = renderNotificationsState(data);
---

<AppShell>
  <section>
    <h1>Notifications</h1>
    <div data-state={state.kind}>
      {
        state.kind === "data" ? (
          <>
            <ul>
              {state.items.map((_, index) => <li>Notification {index + 1}</li>)}
            </ul>
            <p>{state.message}</p>
          </>
        ) : (
          <p>{state.message}</p>
        )
      }
    </div>
  </section>
</AppShell>
