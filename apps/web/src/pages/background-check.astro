---
import AppShell from "../layouts/AppShell.astro";
import { getAuthSessionState, getBackgroundCheckPageData } from "../lib/api-client";
import { renderChecksState } from "../components/checks/ChecksSurface";

const cookieHeader = Astro.request.headers.get("cookie") ?? undefined;
const auth = await getAuthSessionState({ cookieHeader });

if (!auth.authenticated) {
  return Astro.redirect("/");
}

const data = await getBackgroundCheckPageData({ cookieHeader });
const state = renderChecksState(data);
---

<AppShell>
  <section>
    <h1>Background Check</h1>
    <div data-state={state.kind}>
      {
        state.kind === "data" ? (
          <>
            <ul>
              {state.items.map((_, index) => <li>Check {index + 1}</li>)}
            </ul>
            <p>{state.message}</p>
          </>
        ) : (
          <p>{state.message}</p>
        )
      }
    </div>
  </section>
</AppShell>
