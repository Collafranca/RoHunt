---
import AppShell from "../../layouts/AppShell.astro";
import { getAdminStatsPageData, getAuthSessionState } from "../../lib/api-client";
import { renderAdminState } from "../../components/admin/AdminSurface";

const cookieHeader = Astro.request.headers.get("cookie") ?? undefined;
const auth = await getAuthSessionState({ cookieHeader });

if (!auth.authenticated) {
  return Astro.redirect("/");
}

if (!auth.isAdmin) {
  return Astro.redirect("/");
}

const data = await getAdminStatsPageData({ cookieHeader });
const state = renderAdminState(data);
---

<AppShell>
  <section>
    <h1>Admin Stats</h1>
    <div data-state={state.kind}>
      {
        state.kind === "data" ? (
          <>
            <ul>
              {state.items.map((_, index) => <li>Stat {index + 1}</li>)}
            </ul>
            <p>{state.message}</p>
          </>
        ) : (
          <p>{state.message}</p>
        )
      }
    </div>
  </section>
</AppShell>
