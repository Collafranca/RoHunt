---
import AppShell from "../../layouts/AppShell.astro";
import { getAdminStatsPageData } from "../../lib/api-client";
import { renderAdminState } from "../../components/admin/AdminSurface";

const data = await getAdminStatsPageData();
const state = renderAdminState(data);
---

<AppShell>
  <section>
    <h1>Admin Stats</h1>
    <div data-state={state.kind}>
      {
        state.kind === "data" ? (
          <>
            <ul>
              {state.items.map((_, index) => <li>Stat {index + 1}</li>)}
            </ul>
            <p>{state.message}</p>
          </>
        ) : (
          <p>{state.message}</p>
        )
      }
    </div>
  </section>
</AppShell>
