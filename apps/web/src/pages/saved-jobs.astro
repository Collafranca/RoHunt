---
import AppShell from "../layouts/AppShell.astro";
import { getAuthSessionState, getSavedJobsPageData } from "../lib/api-client";
import { renderJobsState } from "../components/jobs/JobsSurface";

const cookieHeader = Astro.request.headers.get("cookie") ?? undefined;
const auth = await getAuthSessionState({ cookieHeader });

if (!auth.authenticated) {
  return Astro.redirect("/");
}

const data = await getSavedJobsPageData({ cookieHeader });
const state = renderJobsState(data);
---

<AppShell>
  <section>
    <h1>Saved Jobs</h1>
    <div data-state={state.kind}>
      {
        state.kind === "data" ? (
          <>
            <ul>
              {state.items.map((_, index) => <li>Saved job {index + 1}</li>)}
            </ul>
            <p>{state.message}</p>
          </>
        ) : (
          <p>{state.message}</p>
        )
      }
    </div>
  </section>
</AppShell>
